# ตั้ง USE_MOCK_DATA=0 เพื่อเชื่อม MySQL จริง
USE_MOCK_DATA=1

# HTTP Server
PORT=4100

# --- Google (ดูคู่มือ docs/GOOGLE_SETUP.md) ---

# google = สร้างผ่าน Google Sheet | local = สร้าง xlsx ในเครื่องอย่างเดียว
EXCEL_EXPORT_MODE=google

# Service Account JSON (ถ้าไม่ตั้ง จะใช้ ./credentials.json)
GOOGLE_CREDENTIALS_PATH=./credentials.json

# โฟลเดอร์ Drive ที่ต้องการเก็บ Google Sheet (คัดลอก ID จาก URL โฟลเดอร์)
# ถ้าตั้งค่านี้ ต้องตั้ง OAuth ด้วย (npm run auth-google)
GOOGLE_DRIVE_FOLDER_ID=

# OAuth — สร้างจาก GCP: Credentials → OAuth client ID (Web application)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4100/oauth2callback
GOOGLE_OAUTH_REFRESH_TOKEN=

# ตั้ง 1 เพื่อเก็บ Sheet ใน Drive แม้ไม่มี GOOGLE_DRIVE_FOLDER_ID
# GOOGLE_KEEP_SHEET=1

# --- Database ---
DATABASE_USER="root"
DATABASE_PASSWORD=
DATABASE_NAME="database_name"
DATABASE_HOST="database_host"
DATABASE_PORT=3306
DATABASE_CONNECTION_LIMIT=20

GOOGLE_OAUTH_REFRESH_TOKEN=